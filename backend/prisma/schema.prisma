generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  SUPER_ADMIN
  TECHNICIAN
  CLIENT_USER
}

enum PlanTier {
  BASICO
  INICIADOR
  PROFESIONAL
  EMPRESARIAL
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELLED
  PAUSED
}

enum FieldType {
  TEXT
  TEXTAREA
  DATE
  NUMBER
  PHOTO
  MULTISELECT
  SIGNATURE
}

enum TicketStatus {
  PENDING
  ASSIGNED
  ON_SITE
  IN_PROGRESS
  PENDING_REPORT
  COMPLETED
  CLOSED
  CANCELLED
  EXPIRED
  REVIEW
  PENDING_APPROVAL
  REOPENED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum VisitStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum PolicyStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum Recurrence {
  MONTHLY
  BIMONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
}

model Subscription {
  id                   String             @id @default(cuid())
  plan                 PlanTier           @default(INICIADOR)
  status               SubscriptionStatus @default(TRIALING)
  currency             String             @default("MXN")
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  trialEndsAt          DateTime?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelledAt          DateTime?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  companyId String       @unique
  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  usageLogs UsageLog[]
}

model UsageLog {
  id             String       @id @default(cuid())
  metric         String       // 'tickets_created'
  quantity       Int
  overageCount   Int          @default(0)
  overageCharge  Decimal      @default(0) @db.Decimal(10, 2)
  periodStart    DateTime
  createdAt      DateTime     @default(now())

  subscriptionId String
  subscription   Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, metric, periodStart])
}

model Company {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  phone     String?
  address   String?
  logoUrl   String?
  // Mexican tax fields
  rfc           String?
  razonSocial   String?
  regimenFiscal String?
  codigoPostal  String?
  giro          String?
  onboardingCompleted Boolean @default(false)
  onboardingStep      Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  products        Product[]
  clients         Client[]
  tickets         Ticket[]
  inventory       InventoryItem[]
  reportTemplates ReportTemplate[]
  policies        Policy[]
  subscription    Subscription?
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role
  phone     String?
  expertise String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  mustChangePassword Boolean  @default(false)

  companyId String?
  company   Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  // only set for CLIENT_USER
  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  assignedTickets Ticket[] @relation("TechnicianTickets")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  description String?
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  equipment Equipment[]
}

model Client {
  id           String   @id @default(cuid())
  name         String
  giro         String?
  // AES-256-GCM encrypted at rest
  contactEmail String
  contactPhone String?
  taxId        String?
  address      String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  templateId String?
  template   ReportTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  users           User[]
  branches        Branch[]
  tickets         Ticket[]
  scheduledVisits ScheduledVisit[]
  policies        Policy[]
}

model Branch {
  id           String   @id @default(cuid())
  name         String
  address      String
  city         String?
  phone        String?
  contactName  String?
  contactEmail String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  equipment        Equipment[]
  tickets          Ticket[]
  scheduledVisits  ScheduledVisit[]
  policyEquipment  PolicyEquipment[]
}

model Equipment {
  id           String    @id @default(cuid())
  name         String
  brand        String?
  serialNumber String?
  model        String?
  notes        String?
  installedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  branchId String
  branch   Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  tickets         Ticket[]
  policyEquipment PolicyEquipment[]
}

model Ticket {
  id          String       @id @default(cuid())
  title       String
  description String?
  status      TicketStatus @default(PENDING)
  priority    Priority     @default(MEDIUM)
  scheduledAt DateTime?
  startedAt   DateTime?
  closedAt    DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  equipmentId String?
  equipment   Equipment? @relation(fields: [equipmentId], references: [id], onDelete: SetNull)

  technicianId String?
  technician   User?   @relation("TechnicianTickets", fields: [technicianId], references: [id], onDelete: SetNull)

  policyId String?
  policy   Policy? @relation(fields: [policyId], references: [id], onDelete: SetNull)

  reviewDocument String?
  reportPdfUrl   String?
  parentTicketId String?
  parentTicket   Ticket?  @relation("FollowUp", fields: [parentTicketId], references: [id])
  followUps      Ticket[] @relation("FollowUp")

  report        TicketReport?
  statusHistory TicketStatusHistory[]
}

model TicketStatusHistory {
  id        String       @id @default(cuid())
  status    TicketStatus
  changedAt DateTime     @default(now())
  changedBy String?

  ticketId String
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model TicketReport {
  id              String   @id @default(cuid())
  folio           String?
  responses       Json
  techSignature   String?
  clientSignature String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  requiresSpareParts Boolean @default(false)
  spareParts         TicketReportSparePart[]

  templateId String
  template   ReportTemplate @relation(fields: [templateId], references: [id])

  ticketId String @unique
  ticket   Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
}

model TicketReportSparePart {
  id              String        @id @default(cuid())
  reportId        String
  report          TicketReport  @relation(fields: [reportId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  quantity        Int
}

model ReportTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  fields  ReportTemplateField[]
  clients Client[]
  reports TicketReport[]
}

model ReportTemplateField {
  id        String    @id @default(cuid())
  label     String
  type      FieldType @default(TEXTAREA)
  required  Boolean   @default(false)
  order     Int       @default(0)
  options   String[]  // only used for MULTISELECT type
  createdAt DateTime  @default(now())

  templateId String
  template   ReportTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
}

model ScheduledVisit {
  id          String      @id @default(cuid())
  requestedAt DateTime
  notes       String?
  status      VisitStatus @default(PENDING)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  branchId String?
  branch   Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  // linked once admin converts visit to ticket
  ticketId String?
}

model InventoryItem {
  id          String   @id @default(cuid())
  name        String
  description String?
  sku         String?
  quantity    Int      @default(0)
  unit        String?
  minStock    Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  spareParts TicketReportSparePart[]
}

model Policy {
  id           String       @id @default(cuid())
  name         String
  status       PolicyStatus @default(ACTIVE)
  startDate    DateTime
  endDate      DateTime
  totalTickets Int
  recurrence   Recurrence
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  companyId String
  company   Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  equipment PolicyEquipment[]
  tickets   Ticket[]
}

model PolicyEquipment {
  id          String    @id @default(cuid())
  policyId    String
  policy      Policy    @relation(fields: [policyId], references: [id], onDelete: Cascade)
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id], onDelete: Cascade)
  branchId    String
  branch      Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([policyId, equipmentId])
}

model Plan {
  id              String   @id @default(cuid())
  tier            PlanTier @unique
  name            String
  badge           String?
  monthlyPrice    Int?
  annualPrice     Int?
  priceLabel      String?
  description     String
  ticketMax       Int?
  techMax         Int?
  adminMax        Int?
  clientMax       Int?
  inventoryMax    Int?
  templateMax     Int?     // 0 = no custom templates; null = unlimited
  allowPolicies   Boolean  @default(true)
  overagePriceMxn Float    @default(0)
  features        String[]
  highlighted     Boolean  @default(false)
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Stripe webhook idempotency: one row per processed event id.
// A duplicate delivery hits the unique primary key and is skipped.
model ProcessedWebhookEvent {
  id          String   @id // the Stripe event id (evt_...)
  type        String
  processedAt DateTime @default(now())
}
