# PostgreSQL connection string from Neon
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# JWT secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-jwt-secret-here"
JWT_EXPIRES_IN="24h"

# AES-256 encryption key (32 bytes = 64 hex chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="your-64-char-hex-key-here"

# CORS allowed origins (comma-separated)
ALLOWED_ORIGINS="http://localhost:3000,https://deployr.mx,https://www.deployr.mx"

# Vercel Blob — get token from Vercel Dashboard → Storage → your blob store → .env.local tab
DEPLOYR_BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

PORT=4000
NODE_ENV=development

# Frontend URL (used in approval email links)
FRONTEND_URL="https://deployr.mx"

# Google Maps — Places API key (server-side proxy for address autocomplete)
GOOGLE_MAPS_KEY="your-google-maps-api-key"

# SMTP — for approval email notifications
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your@email.com"
SMTP_PASS="your-app-password"
SMTP_FROM="deployr <no-reply@deployr.mx>"

# ── Stripe ─────────────────────────────────────────────────────────────────
# Dashboard → Developers → API Keys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Dashboard → Products → create one product per plan → copy Price IDs
STRIPE_PRICE_BASICO_MONTHLY="price_..."
STRIPE_PRICE_BASICO_ANNUAL="price_..."
STRIPE_PRICE_INICIADOR_MONTHLY="price_..."
STRIPE_PRICE_INICIADOR_ANNUAL="price_..."
STRIPE_PRICE_PROFESIONAL_MONTHLY="price_..."
STRIPE_PRICE_PROFESIONAL_ANNUAL="price_..."

